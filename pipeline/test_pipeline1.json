					"expression": {
						"value": "@equals(variables('file_type'),'csv')",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "Set variable2",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "message",
								"value": "not a csv file"
							}
						}
					],
					"ifTrueActivities": [
						{
							"name": "Set variable1",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "message",
								"value": "csv"
							}
						}
					]
				}
			}
		],
		"variables": {
			"file_type": {
				"type": "String",
				"defaultValue": "csv"
